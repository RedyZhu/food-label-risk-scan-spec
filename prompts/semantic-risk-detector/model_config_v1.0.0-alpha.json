{
  "module_name": "SemanticRiskDetector",
  "module_alias": "SRD",
  "module_version": "v1.0.0-alpha",
  "runtime": "dify",
  "model_provider": "qwen",
  "model_name": "qwen3.5-plus",
  "generation_config": {
    "temperature": 0.2,
    "top_p": 0.3
